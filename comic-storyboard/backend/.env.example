# === 文生文 LLM（通义千问，兼容 OpenAI 格式）===
# 留空则自动使用 mock 假数据，无需 Key 也能跑通测试
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# === 生图（通义万相 wan2.5-t2i，V2 实现）===
IMAGE_API_KEY=
IMAGE_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
IMAGE_MODEL=wan2.5-t2i

# === Gemini（Nano Banana，可选）===
GOOGLE_API_KEY=

# === 阿里云 OSS（V2 实现）===
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_BUCKET=comic-storyboard

# === MySQL（V3 实现）===
DB_URL=mysql://user:pass@localhost/comic_storyboard
